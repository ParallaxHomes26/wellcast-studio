{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".."
  },
  "include": [
    "./**/*.ts",
    "../artifacts/api-server/src/**/*.ts",
    "../lib/db/src/**/*.ts",
    "../lib/api-zod/src/**/*.ts"
  ]
}
