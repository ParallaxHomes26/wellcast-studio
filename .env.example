# ─────────────────────────────────────────────────────────────────────────────
# Wellcast Studio — Environment Variables
#
# Copy this file to .env (never commit .env) and fill in the values.
# Variables prefixed with VITE_ are bundled into the frontend at build time.
# All others are server-side only.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────

# Public production URL (used for Stripe success/cancel redirects + CORS)
# e.g. https://getwellcast.com — no trailing slash
APP_URL=https://getwellcast.com

# ── Supabase ──────────────────────────────────────────────────────────────────

# Project URL — same value used by both server and client
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────────────────────

# Secret key — SERVER ONLY
STRIPE_SECRET_KEY=sk_live_...

# Publishable key — safe to expose in the browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret — from Stripe Dashboard → Webhooks → signing secret
# For local dev use: stripe listen --forward-to localhost:8080/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Anthropic ─────────────────────────────────────────────────────────────────

# Anthropic API key — SERVER ONLY
ANTHROPIC_API_KEY=sk-ant-...

# ── Session ───────────────────────────────────────────────────────────────────

# Any long random string (openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-long-random-string

# ── Logging ───────────────────────────────────────────────────────────────────

# One of: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ── Object Storage (Replit only — not used on Vercel) ─────────────────────────

# Set automatically by Replit; leave blank outside Replit
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# ── Dev / Runtime ─────────────────────────────────────────────────────────────

# Set by Replit automatically — not needed on Vercel
# PORT=8080
# BASE_PATH=/
# REPLIT_DOMAINS=
# REPLIT_DEV_URL=
