{
  "version": 2,
  "buildCommand": "pnpm run typecheck:libs && pnpm --filter @workspace/wellcast-studio run build",
  "outputDirectory": "artifacts/wellcast-studio/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://workspaceapi-server-production-91a1.up.railway.app/api/:path*" },
    { "source": "/:path*",     "destination": "/" }
  ]
}
